LIBRARY = libmy_sc.a

# Все .c файлы в текущей директории
SOURCES = $(wildcard *.c)

# Список объектных файлов (.o), основанный на .c файлах
OBJECTS = $(SOURCES:.c=.o)

# Компилятор и флаги компиляции
CC = gcc
CFLAGS = -Wall -g

# Правило по умолчанию для сборки статической библиотеки
all: $(LIBRARY)

# Правило для создания статической библиотеки из объектных файлов
$(LIBRARY): $(OBJECTS)
	ar rcs $@ $^

# Правило для компиляции .c файлов в .o файлы
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# Чистим объектные файлы и библиотеку
clean:
	rm -f $(OBJECTS) $(LIBRARY)

.PHONY: all clean
